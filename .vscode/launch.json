{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch file",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${file}"
        },

        {
            "name": "Debug REST API",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/server/main.go",
            "env": {
                "DATABASE_URL": "host=localhost user=postgres password=pass dbname=tododb port=5432 sslmode=disable"
            }
        }
    ]
}